[workspace]
resolver = "2"
members = [
    "xlsdwan",
    "xlsdwan-gui/src-tauri",
    "xlsdwan-rpc-build",
    "xlsdwan-web",
    "xlsdwan-contrib/easytier-ffi",
    "xlsdwan-contrib/easytier-uptime",
]
default-members = ["xlsdwan", "xlsdwan-web"]
exclude = [
    "easytier-contrib/easytier-ohrs", # it needs ohrs sdk
]

[profile.dev]
panic = "unwind"
debug = 2

[profile.release]
panic = "abort"
lto = true
codegen-units = 1
opt-level = 3
strip = true
